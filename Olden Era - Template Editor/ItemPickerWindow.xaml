<Window x:Class="Olden_Era___Template_Editor.ItemPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource S.Item.001}" Width="900" Height="800"
        Icon="pack://application:,,,/favicon.ico"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        MinWidth="500" MinHeight="440"
        WindowStyle="None"
        Background="#0E1117"
        Foreground="#E7EBF3"
        FontFamily="Segoe UI" FontSize="13">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32" ResizeBorderThickness="5"
                      GlassFrameThickness="0,0,0,1" UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Border BorderBrush="{StaticResource BrushBorder}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="32"/>
                <RowDefinition Height="1"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Grid Grid.Row="0" Background="#12151D">
                <TextBlock x:Name="TxtWindowTitle" Text="{DynamicResource S.Item.001}"
                           FontSize="12" FontWeight="SemiBold"
                           Foreground="{StaticResource BrushText}"
                           VerticalAlignment="Center" Margin="10,0,0,0"
                           MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"/>
                <Button Content="✕" Style="{StaticResource TitleBarCloseButton}"
                        HorizontalAlignment="Right"
                        ToolTip="{DynamicResource S.M.009}" Click="BtnClose_Click"/>
            </Grid>

            <!-- Gold divider -->
            <Rectangle Grid.Row="1" Fill="{StaticResource BrushBorder}"/>

            <!-- Content -->
            <DockPanel Grid.Row="2" Margin="12" Background="{StaticResource BrushPanel}">

                <!-- Search box -->
                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                    <TextBox x:Name="TxtSearch"
                             TextChanged="TxtSearch_TextChanged"
                             Height="28"/>
                </StackPanel>

                <!-- Buttons -->
                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                            HorizontalAlignment="Right" Margin="0,8,0,0">
                    <Button x:Name="BtnAdd" Content="{DynamicResource S.Spell.003}"
                            Width="120" Height="28" Margin="0,0,8,0"
                            IsDefault="True"
                            Click="BtnAdd_Click"/>
                    <Button Content="{DynamicResource S.Spell.004}"
                            Width="80" Height="28"
                            IsCancel="True"
                            Click="BtnCancel_Click"/>
                </StackPanel>

                <!-- Custom ID row -->
                <Grid DockPanel.Dock="Bottom" Margin="0,6,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="110"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{DynamicResource S.Item.002}"
                               VerticalAlignment="Center" Margin="0,0,6,0"
                               Foreground="{StaticResource BrushTextDim}" FontSize="12"/>
                    <TextBox Grid.Column="1" x:Name="TxtCustomId"
                             Height="26" FontFamily="Consolas" FontSize="11"
                             ToolTip="{DynamicResource S.Item.003}"/>
                    <Button Grid.Column="3" Content="{DynamicResource S.Item.004}"
                            Height="26"
                            Click="BtnAddCustom_Click"/>
                </Grid>

                <!-- Category tree -->
                <TreeView x:Name="TvItems"
                          PreviewMouseLeftButtonDown="TvItems_PreviewMouseLeftButtonDown"
                          MouseDoubleClick="TvItems_MouseDoubleClick"
                          Background="{StaticResource BrushInput}"
                          Foreground="{StaticResource BrushText}"
                          BorderBrush="{StaticResource BrushBorder}" BorderThickness="1">
                    <TreeView.Resources>
                        <Style TargetType="TreeViewItem">
                            <Setter Property="Background"  Value="Transparent"/>
                            <Setter Property="Foreground"  Value="{StaticResource BrushText}"/>
                            <Setter Property="Padding"     Value="3,2"/>
                            <Setter Property="IsExpanded"  Value="True"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#232B3C"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="Transparent"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TreeView.Resources>
                </TreeView>

            </DockPanel>
        </Grid>
    </Border>
</Window>
