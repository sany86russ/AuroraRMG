<Window x:Class="Olden_Era___Template_Editor.SpellPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource S.Spell.001}" Width="480" Height="620"
        Icon="pack://application:,,,/favicon.ico"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        MinWidth="380" MinHeight="440"
        WindowStyle="None"
        Background="#0E1117"
        Foreground="#E7EBF3"
        FontFamily="Segoe UI" FontSize="13">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32" ResizeBorderThickness="5"
                      GlassFrameThickness="0,0,0,1" UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Border BorderBrush="{StaticResource BrushBorder}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="32"/>
                <RowDefinition Height="1"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Grid Grid.Row="0" Background="#12151D">
                <TextBlock Text="{DynamicResource S.Spell.001}"
                           FontSize="12" FontWeight="SemiBold"
                           Foreground="{StaticResource BrushText}"
                           VerticalAlignment="Center" Margin="10,0,0,0"
                           MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"/>
                <Button Content="✕" Style="{StaticResource TitleBarCloseButton}"
                        HorizontalAlignment="Right"
                        ToolTip="{DynamicResource S.M.009}" Click="BtnClose_Click"/>
            </Grid>

            <!-- Gold divider -->
            <Rectangle Grid.Row="1" Fill="{StaticResource BrushBorder}"/>

            <!-- Content -->
            <DockPanel Grid.Row="2" Margin="12" Background="{StaticResource BrushPanel}">

                <!-- Search box -->
                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                    <TextBox x:Name="TxtSearch"
                             TextChanged="TxtSearch_TextChanged"
                             Height="28"/>
                </StackPanel>

                <!-- Make free + Buttons (bottom) -->
                <Grid DockPanel.Dock="Bottom" Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <CheckBox Grid.Column="0" x:Name="ChkMakeFree"
                              Content="{DynamicResource S.Spell.002}"
                              VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button x:Name="BtnAdd" Content="{DynamicResource S.Spell.003}"
                                Width="120" Height="28" Margin="0,0,8,0"
                                IsDefault="True" IsEnabled="False"
                                Click="BtnAdd_Click"/>
                        <Button Content="{DynamicResource S.Spell.004}"
                                Width="80" Height="28"
                                IsCancel="True"
                                Click="BtnCancel_Click"/>
                    </StackPanel>
                </Grid>

                <!-- Spell tree -->
                <TreeView x:Name="TvSpells"
                          PreviewMouseLeftButtonDown="TvSpells_PreviewMouseLeftButtonDown"
                          MouseDoubleClick="TvSpells_MouseDoubleClick"
                          Background="{StaticResource BrushInput}"
                          Foreground="{StaticResource BrushText}"
                          BorderBrush="{StaticResource BrushBorder}" BorderThickness="1">
                    <TreeView.Resources>
                        <Style TargetType="TreeViewItem">
                            <Setter Property="Background"  Value="Transparent"/>
                            <Setter Property="Foreground"  Value="{StaticResource BrushText}"/>
                            <Setter Property="Padding"     Value="3,2"/>
                            <Setter Property="IsExpanded"  Value="True"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#232B3C"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="Transparent"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TreeView.Resources>
                </TreeView>

            </DockPanel>
        </Grid>
    </Border>
</Window>
