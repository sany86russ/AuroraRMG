<Window x:Class="Olden_Era___Template_Editor.UpdateProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource S.Upd.001}"
        Width="440" Height="220"
        Icon="pack://application:,,,/favicon.ico"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        Background="#0E1117"
        Foreground="#E7EBF3"
        FontFamily="Segoe UI" FontSize="13"
        Closing="Window_Closing">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32" ResizeBorderThickness="0"
                      GlassFrameThickness="0,0,0,1" UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Border BorderBrush="{StaticResource BrushBorder}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="32"/>
                <RowDefinition Height="1"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Grid Grid.Row="0" Background="#12151D">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                    <Image Source="pack://application:,,,/favicon.ico" Width="16" Height="16"
                           Margin="0,0,8,0" VerticalAlignment="Center"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                    <TextBlock Text="{DynamicResource S.Upd.001}"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="{StaticResource BrushText}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>

            <Rectangle Grid.Row="1" Fill="{StaticResource BrushBorder}"/>

            <!-- Body -->
            <Grid Grid.Row="2" Margin="22,18,22,18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" x:Name="TitleText"
                           Text="{DynamicResource S.Upd.002}"
                           FontSize="14" FontWeight="SemiBold"
                           Foreground="{StaticResource BrushText}"
                           Margin="0,0,0,4"/>

                <TextBlock Grid.Row="1" x:Name="StatusText"
                           Text="{DynamicResource S.Upd.003}"
                           FontSize="12"
                           Foreground="{StaticResource BrushTextDim}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,16"/>

                <ProgressBar Grid.Row="2" x:Name="ProgressBar"
                             Height="10" Minimum="0" Maximum="100" Value="0"
                             VerticalAlignment="Top"
                             Background="#141925"
                             BorderBrush="{StaticResource BrushBorder}"
                             BorderThickness="1"
                             Foreground="{StaticResource BrushGold}"/>

                <Button Grid.Row="3" x:Name="CancelButton"
                        Content="{DynamicResource S.Spell.004}" Width="110" Height="32"
                        HorizontalAlignment="Right"
                        Click="CancelButton_Click"/>
            </Grid>
        </Grid>
    </Border>
</Window>
