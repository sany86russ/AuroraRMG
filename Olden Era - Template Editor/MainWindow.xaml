<Window x:Class="Olden_Era___Template_Editor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Olden_Era___Template_Editor.Models"
        mc:Ignorable="d"
        Title="AuroraRMG"
        Icon="pack://application:,,,/favicon.ico"
        Height="820" Width="1240"
        MinHeight="780" MinWidth="1160"
        WindowStyle="None"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        StateChanged="Window_StateChanged"
        Loaded="Window_Loaded"
        Background="#0E1117"
        FontFamily="Segoe UI, Arial, sans-serif">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="46"
                      ResizeBorderThickness="5"
                      GlassFrameThickness="0,0,0,1"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.InputBindings>
        <KeyBinding Key="N" Modifiers="Ctrl"       Command="{x:Static ApplicationCommands.New}"/>
        <KeyBinding Key="O" Modifiers="Ctrl"       Command="{x:Static ApplicationCommands.Open}"/>
        <KeyBinding Key="S" Modifiers="Ctrl"       Command="{x:Static ApplicationCommands.Save}"/>
        <KeyBinding Key="S" Modifiers="Ctrl+Shift" Command="{x:Static ApplicationCommands.SaveAs}"/>
    </Window.InputBindings>
    <Window.CommandBindings>
        <CommandBinding Command="{x:Static ApplicationCommands.New}"    Executed="BtnNew_Click"/>
        <CommandBinding Command="{x:Static ApplicationCommands.Open}"   Executed="BtnOpen_Click"/>
        <CommandBinding Command="{x:Static ApplicationCommands.Save}"   Executed="BtnSave_Click"/>
        <CommandBinding Command="{x:Static ApplicationCommands.SaveAs}" Executed="BtnSaveAs_Click"/>
    </Window.CommandBindings>

    <!-- Hidden combo boxes required by code-behind -->
    <Window.Resources>
        <Style x:Key="RowSpacer" TargetType="RowDefinition">
            <Setter Property="Height" Value="8"/>
        </Style>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <!-- Outer border gives the window its themed frame -->
    <Border BorderBrush="{StaticResource BrushBorder}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="46"/>    <!-- command header bar -->
                <RowDefinition Height="1"/>     <!-- divider -->
                <RowDefinition Height="*"/>     <!-- page content -->
            </Grid.RowDefinitions>

            <!-- ════════ COMMAND HEADER BAR ══════════════════════════════ -->
            <Grid Grid.Row="0" Background="#12151D">
                <!-- Brand + title (drag region) -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0,0,0"
                            HorizontalAlignment="Left"
                            MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Image Source="pack://application:,,,/favicon.ico" Width="22" Height="22"
                           VerticalAlignment="Center" Margin="0,0,10,0"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                    <!-- Wordmark: Aurora + RMG (cyan) -->
                    <TextBlock VerticalAlignment="Center">
                        <Run Text="Aurora" FontSize="15" FontWeight="Bold"
                             Foreground="{StaticResource BrushText}"/><Run Text="RMG" FontSize="15" FontWeight="Bold"
                             Foreground="{StaticResource BrushCyan}"/>
                    </TextBlock>
                    <!-- Version badge (target for auto-update display) -->
                    <Border CornerRadius="6" Padding="7,1" Margin="10,0,0,0"
                            VerticalAlignment="Center"
                            Background="#1B2236"
                            BorderBrush="{StaticResource BrushGoldDim}" BorderThickness="1">
                        <TextBlock x:Name="TxtVersionBadge"
                                   FontSize="10.5" FontWeight="SemiBold"
                                   Foreground="{StaticResource BrushGold}"
                                   VerticalAlignment="Center" Text="v0.0"/>
                    </Border>
                    <!-- Separator -->
                    <Border Width="1" Height="16" Background="{StaticResource BrushBorder}"
                            Margin="12,0,0,0" VerticalAlignment="Center"/>
                    <!-- Current file (secondary, dimmed) -->
                    <TextBlock x:Name="TxtWindowTitle"
                               FontSize="11.5"
                               Foreground="{StaticResource BrushTextDim}"
                               VerticalAlignment="Center" Margin="12,1,0,0"/>
                </StackPanel>

                <!-- File actions · links · window buttons (right) -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Stretch">

                    <!-- File actions (relocated from the old toolbar) -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,6,0"
                                WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button Content="🔄" Width="38" Margin="0,0,4,0" Click="BtnNew_Click"    Style="{StaticResource ToolbarButton}" ToolTip="Сбросить настройки (Ctrl+N)"/>
                        <Button Content="📂" Width="38" Margin="0,0,4,0" Click="BtnOpen_Click"   Style="{StaticResource ToolbarButton}" ToolTip="Открыть настройки (Ctrl+O)"/>
                        <Button Content="💾" Width="38" Margin="0,0,4,0" Click="BtnSave_Click"   Style="{StaticResource ToolbarButton}" ToolTip="Сохранить настройки (Ctrl+S)"/>
                        <Button Content="💾…" Width="44" Margin="0,0,0,0" Click="BtnSaveAs_Click" Style="{StaticResource ToolbarButton}" ToolTip="Сохранить настройки как… (Ctrl+Shift+S)"/>
                    </StackPanel>

                    <Border Width="1" Background="{StaticResource BrushBorder}" Margin="8,11" VerticalAlignment="Stretch"/>

                    <!-- Window caption buttons -->
                    <Button Content="🗕" Style="{StaticResource TitleBarButton}"
                            ToolTip="Свернуть" Click="BtnMinimize_Click"/>
                    <Button x:Name="BtnMaximize" Content="🗖" Style="{StaticResource TitleBarButton}"
                            ToolTip="Развернуть" Click="BtnMaximize_Click"/>
                    <Button Content="✕" Style="{StaticResource TitleBarCloseButton}"
                            ToolTip="Закрыть" Click="BtnClose_Click"/>
                </StackPanel>
            </Grid>

            <!-- Gold divider line under title bar -->
            <Rectangle Grid.Row="1" Fill="{StaticResource BrushBorder}"/>

            <!-- ════════ PAGE CONTENT ═══════════════════════════════════ -->
            <Grid Grid.Row="2" Margin="14,10,14,12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- WIP warning -->
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="*"/>     <!-- main content -->
                </Grid.RowDefinitions>

                <!-- ════════ STATUS BANNERS (update + WIP) ═════════════════════ -->
                <StackPanel Grid.Row="0">

                    <!-- Auto-update banner (hidden until a newer release is found) -->
                    <Border x:Name="UpdateBanner" Visibility="Collapsed"
                            Background="#16213A"
                            BorderBrush="{StaticResource BrushGold}"
                            BorderThickness="1" CornerRadius="8"
                            Padding="12,8" Margin="0,0,0,8">
                        <DockPanel LastChildFill="True">
                            <TextBlock Text="✨" FontSize="14" VerticalAlignment="Center"
                                       Margin="0,0,10,0" DockPanel.Dock="Left"/>
                            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right"
                                        VerticalAlignment="Center" Margin="10,0,0,0">
                                <Button x:Name="BtnUpdateNow" Content="Обновить"
                                        Style="{StaticResource GenerateButton}"
                                        Height="30" MinWidth="104" FontSize="13"
                                        Click="BtnUpdateNow_Click"/>
                                <Button x:Name="BtnUpdateNotes" Content="Что нового"
                                        Margin="8,0,0,0" Height="30" MinWidth="96"
                                        Click="BtnUpdateNotes_Click"/>
                                <Button x:Name="BtnUpdateDismiss" Content="Позже"
                                        Margin="8,0,0,0" Height="30" MinWidth="72"
                                        Click="BtnUpdateDismiss_Click"/>
                            </StackPanel>
                            <TextBlock x:Name="TxtUpdateBanner"
                                       VerticalAlignment="Center" TextWrapping="Wrap"
                                       Foreground="{StaticResource BrushText}" FontSize="12"/>
                        </DockPanel>
                    </Border>

                    <!-- WIP warning -->
                    <Border Background="{StaticResource BrushWarnBg}"
                            BorderBrush="{StaticResource BrushWarnBorder}"
                            BorderThickness="1" CornerRadius="8"
                            Padding="12,8">
                        <TextBlock x:Name="TxtWipWarning"
                                   Foreground="{StaticResource BrushWarnText}"
                                   FontSize="11" TextWrapping="Wrap"/>
                    </Border>
                </StackPanel>

        <!-- ════════ MAIN CONTENT — left nav rail + content + preview ═════════ -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="290"/>
            </Grid.ColumnDefinitions>

            <TabControl x:Name="MainTabs"
                        Grid.Column="0"
                        TabStripPlacement="Left"
                        ItemContainerStyle="{StaticResource SidebarTab}"
                        VerticalContentAlignment="Stretch">
                <TabItem Header="Правила">
                <Grid Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- 1st row -->
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>  <!-- 2nd row -->
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="*"/>     <!-- 3rd row -->
                </Grid.RowDefinitions>

                <!-- TEMPLATE -->
                <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource SectionBorder}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <TextBlock Text="◆  ШАБЛОН" Style="{StaticResource SectionHeader}"/>
                        <DockPanel Margin="0,0,0,8">
                            <Label Content="Пресет" DockPanel.Dock="Left" VerticalAlignment="Center"/>
                            <ComboBox x:Name="CmbPreset" Margin="8,0,0,0"
                                      SelectionChanged="CmbPreset_Changed"
                                      ToolTip="Быстрый старт: загрузить готовую конфигурацию (упор на 1v1)"/>
                        </DockPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="155"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Label Grid.Row="0" Grid.Column="0" Content="Название шаблона"/>
                            <TextBox Grid.Row="0" Grid.Column="1" x:Name="TxtTemplateName" Text="Свой шаблон"/>
                            <Label Grid.Row="2" Grid.Column="0" Content="Размер карты"/>
                            <ComboBox x:Name="CmbMapSize" Grid.Row="2" Grid.Column="1" SelectionChanged="CmbMapSize_SelectionChanged"/>
                            <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2">
                                <CheckBox x:Name="ChkExperimentalMapSizes"
                                          Content="Экспериментальные большие карты"
                                          Margin="0,6,0,0"
                                          Visibility="Visible"
                                          Checked="ChkExperimentalMapSizes_Changed"
                                          Unchecked="ChkExperimentalMapSizes_Changed"/>
                                <TextBlock x:Name="TxtExperimentalMapSizeWarning"
                                           Foreground="{StaticResource BrushTextDim}"
                                           FontSize="11"
                                           TextWrapping="Wrap"
                                           Margin="0,4,0,0"
                                           Visibility="Collapsed"
                                           Text="Добавляет размеры от 256x256 до 512x512. Официальные шаблоны заканчиваются на 240x240, поэтому большие карты могут не загрузиться, зависнуть или вести себя непредсказуемо."/>
                            </StackPanel>
                            <DockPanel Grid.Row="6" Grid.Column="0">
                                <Label Content="Игроки" DockPanel.Dock="Left"/>
                                <TextBlock x:Name="TxtPlayers" Text="2" DockPanel.Dock="Right"
                                           HorizontalAlignment="Right" VerticalAlignment="Center"
                                           Margin="0,0,4,0" Style="{StaticResource ValueText}"/>
                            </DockPanel>
                            <Slider Grid.Row="6" Grid.Column="1" x:Name="SldPlayers"
                                    Minimum="2" Maximum="8" Value="2"
                                    TickFrequency="1" IsSnapToTickEnabled="True"
                                    ValueChanged="Slider_ValueChanged"/>
                        </Grid>
                    </StackPanel>
                    </ScrollViewer>
                </Border>

                <!-- HEROES -->
                <Border Grid.Row="0" Grid.Column="2" Style="{StaticResource SectionBorder}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <TextBlock Text="◆  ГЕРОИ" Style="{StaticResource SectionHeader}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="185"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="4"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="4"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <DockPanel Grid.Row="0" Grid.Column="0">
                                <Label Content="Начальный лимит героев" Padding="5,2" DockPanel.Dock="Left"/>
                                <TextBlock x:Name="TxtHeroMin" Text="4" DockPanel.Dock="Right"
                                           HorizontalAlignment="Right" VerticalAlignment="Center"
                                           Margin="0,0,4,0" Style="{StaticResource ValueText}"/>
                            </DockPanel>
                            <Slider Grid.Row="0" Grid.Column="1" x:Name="SldHeroMin"
                                    Minimum="1" Maximum="12" Value="4"
                                    TickFrequency="1" IsSnapToTickEnabled="True"
                                    ValueChanged="Slider_ValueChanged"/>

                            <DockPanel Grid.Row="2" Grid.Column="0">
                                <Label Content="Макс. лимит героев" Padding="5,2" DockPanel.Dock="Left"/>
                                <TextBlock x:Name="TxtHeroMax" Text="8" DockPanel.Dock="Right"
                                           HorizontalAlignment="Right" VerticalAlignment="Center"
                                           Margin="0,0,4,0" Style="{StaticResource ValueText}"/>
                            </DockPanel>
                            <Slider Grid.Row="2" Grid.Column="1" x:Name="SldHeroMax"
                                    Minimum="1" Maximum="12" Value="8"
                                    TickFrequency="1" IsSnapToTickEnabled="True"
                                    ValueChanged="Slider_ValueChanged"/>

                            <DockPanel Grid.Row="4" Grid.Column="0">
                                <Label Content="Прирост лимита за замок" Padding="5,2" DockPanel.Dock="Left"/>
                                <TextBlock x:Name="TxtHeroIncrement" Text="1" DockPanel.Dock="Right"
                                           HorizontalAlignment="Right" VerticalAlignment="Center"
                                           Margin="0,0,4,0" Style="{StaticResource ValueText}"/>
                            </DockPanel>
                            <Slider Grid.Row="4" Grid.Column="1" x:Name="SldHeroIncrement"
                                    Minimum="0" Maximum="10" Value="1"
                                    TickFrequency="1" IsSnapToTickEnabled="True"
                                    ValueChanged="Slider_ValueChanged"/>
                        </Grid>
                        <CheckBox x:Name="ChkSingleHeroMode" Content="Режим одного героя"
                                  Margin="5,8,5,2" VerticalContentAlignment="Center"
                                  Checked="ChkSingleHeroMode_Changed"
                                  Unchecked="ChkSingleHeroMode_Changed"/>
                    </StackPanel>
                    </ScrollViewer>
                </Border>

                <!-- ADVANCED GAME RULES -->
                <Border Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3" x:Name="PnlAdvancedGameRules" Style="{StaticResource SectionBorder}">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="◆ ПРАВИЛА ИГРЫ" Style="{StaticResource SectionHeader}"/>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="205"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="10"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="10"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Label Grid.Row="4" Grid.Column="0" Content="Основное условие победы"/>
                                <ComboBox Grid.Row="4" Grid.Column="1" x:Name="CmbVictory"
                                          SelectionChanged="CmbVictory_SelectionChanged"/>

                                <DockPanel Grid.Row="0" Grid.Column="0">
                                    <Label Content="Опыт законов фракций" DockPanel.Dock="Left"/>
                                    <TextBlock x:Name="TxtFactionLawsExp" Text="100%" DockPanel.Dock="Right"
                                               HorizontalAlignment="Right" VerticalAlignment="Center"
                                               Margin="0,0,10,0" Style="{StaticResource ValueText}"/>
                                </DockPanel>
                                <Slider Grid.Row="0" Grid.Column="1" x:Name="SldFactionLawsExp"
                                        Minimum="25" Maximum="200" Value="100"
                                        TickFrequency="25" IsSnapToTickEnabled="True"
                                        ValueChanged="Slider_ValueChanged"/>

                                        <DockPanel Grid.Row="2" Grid.Column="0">
                                    <Label Content="Опыт астрологии" DockPanel.Dock="Left"/>
                                    <TextBlock x:Name="TxtAstrologyExp" Text="100%" DockPanel.Dock="Right"
                                               HorizontalAlignment="Right" VerticalAlignment="Center"
                                               Margin="0,0,10,0" Style="{StaticResource ValueText}"/>
                                </DockPanel>
                                <Slider Grid.Row="2" Grid.Column="1" x:Name="SldAstrologyExp"
                                        Minimum="25" Maximum="200" Value="100"
                                        TickFrequency="25" IsSnapToTickEnabled="True"
                                        ValueChanged="Slider_ValueChanged"/>
                            </Grid>

                            <StackPanel Margin="0,10,0,0">
                                <CheckBox x:Name="ChkLostStartCity"
                                          Content="Поражение при потере стартового города"
                                          Checked="WinConditionOption_Changed"
                                          Unchecked="WinConditionOption_Changed"/>
                                <Grid x:Name="PnlLostStartCityDetails" Margin="18,3,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="167"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <DockPanel Grid.Column="0">
                                        <Label Content="День потери города" Padding="5,2" DockPanel.Dock="Left"/>
                                        <TextBlock x:Name="TxtLostStartCityDay" Text="3" DockPanel.Dock="Right"
                                                   HorizontalAlignment="Right" VerticalAlignment="Center"
                                                   Margin="0,0,0,0" Style="{StaticResource ValueText}"/>
                                    </DockPanel>
                                    <Slider Grid.Column="1" x:Name="SldLostStartCityDay"
                                            Minimum="1" Maximum="30" Value="3"
                                            TickFrequency="1" IsSnapToTickEnabled="True"
                                            ValueChanged="Slider_ValueChanged"/>
                                </Grid>

                                <CheckBox x:Name="ChkLostStartHero"
                                          Content="Поражение при потере стартового героя"
                                          Checked="WinConditionOption_Changed"
                                          Unchecked="WinConditionOption_Changed"/>

                                <CheckBox x:Name="ChkCityHold"
                                          Content="Победа за удержание нейтр. города"
                                          Margin="0,6,0,0"
                                          Checked="WinConditionOption_Changed"
                                          Unchecked="WinConditionOption_Changed"/>
                                <Grid x:Name="PnlCityHoldDetails" Margin="18,3,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="167"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <DockPanel Grid.Column="0">
                                        <Label Content="Дней удержания" Padding="5,2" DockPanel.Dock="Left"/>
                                        <TextBlock x:Name="TxtCityHoldDays" Text="6" DockPanel.Dock="Right"
                                                   HorizontalAlignment="Right" VerticalAlignment="Center"
                                                   Margin="0,0,4,0" Style="{StaticResource ValueText}"/>
                                    </DockPanel>
                                    <Slider Grid.Column="1" x:Name="SldCityHoldDays"
                                            Minimum="1" Maximum="30" Value="6"
                                            TickFrequency="1" IsSnapToTickEnabled="True"
                                            ValueChanged="Slider_ValueChanged"/>
                                </Grid>

                                <CheckBox x:Name="ChkGladiatorArena"
                                          Content="Правила гладиаторской арены"
                                          Margin="0,6,0,0"
                                          Checked="WinConditionOption_Changed"
                                          Unchecked="WinConditionOption_Changed" Visibility="Collapsed"/>
                                <Grid x:Name="PnlGladiatorDetails" Margin="18,3,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="167"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="4"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <DockPanel Grid.Row="0" Grid.Column="0">
                                        <Label Content="Задержка арены" Padding="5,2" DockPanel.Dock="Left"/>
                                        <TextBlock x:Name="TxtGladiatorDelay" Text="30" DockPanel.Dock="Right"
                                                   HorizontalAlignment="Right" VerticalAlignment="Center"
                                                   Margin="0,0,4,0" Style="{StaticResource ValueText}"/>
                                    </DockPanel>
                                    <Slider Grid.Row="0" Grid.Column="1" x:Name="SldGladiatorDelay"
                                            Minimum="1" Maximum="60" Value="30"
                                            TickFrequency="1" IsSnapToTickEnabled="True"
                                            ValueChanged="Slider_ValueChanged"/>
                                    <DockPanel Grid.Row="2" Grid.Column="0">
                                        <Label Content="День подсчёта арены" Padding="5,2" DockPanel.Dock="Left"/>
                                        <TextBlock x:Name="TxtGladiatorCountDay" Text="3" DockPanel.Dock="Right"
                                                   HorizontalAlignment="Right" VerticalAlignment="Center"
                                                   Margin="0,0,4,0" Style="{StaticResource ValueText}"/>
                                    </DockPanel>
                                    <Slider Grid.Row="2" Grid.Column="1" x:Name="SldGladiatorCountDay"
                                            Minimum="1" Maximum="30" Value="3"
                                            TickFrequency="1" IsSnapToTickEnabled="True"
                                            ValueChanged="Slider_ValueChanged"/>
                                </Grid>

                                <CheckBox x:Name="ChkTournament"
                                          Content="Правила турнира"
                                          Margin="0,6,0,0"
                                          Checked="WinConditionOption_Changed"
                                          Unchecked="WinConditionOption_Changed"/>
                                <Grid x:Name="PnlTournamentDetails" Margin="18,3,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="167"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="4"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="4"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="8"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <DockPanel Grid.Row="0" Grid.Column="0">
                                        <Label Content="Очков для победы" Padding="5,2" DockPanel.Dock="Left"/>
                                        <TextBlock x:Name="TxtTournamentPointsToWin" Text="2" DockPanel.Dock="Right"
                                                   HorizontalAlignment="Right" VerticalAlignment="Center"
                                                   Margin="0,0,0,0" Style="{StaticResource ValueText}"/>
                                    </DockPanel>
                                    <Slider Grid.Row="0" Grid.Column="1" x:Name="SldTournamentPointsToWin"
                                            Minimum="1" Maximum="10" Value="2"
                                            TickFrequency="1" IsSnapToTickEnabled="True"
                                            ValueChanged="Slider_ValueChanged"/>
                                    <DockPanel Grid.Row="2" Grid.Column="0">
                                        <Label Content="Первый бой в день " Padding="5,2" DockPanel.Dock="Left"/>
                                        <TextBlock x:Name="TxtTournamentFirstTournamentDay" Text="8" DockPanel.Dock="Right"
                                                   HorizontalAlignment="Right" VerticalAlignment="Center"
                                                   Margin="0,0,0,0" Style="{StaticResource ValueText}"/>
                                    </DockPanel>
                                    <Slider Grid.Row="2" Grid.Column="1" x:Name="SldTournamentFirstTournamentDay"
                                            Minimum="3" Maximum="30" Value="14"
                                            TickFrequency="1" IsSnapToTickEnabled="True"
                                            ValueChanged="Slider_ValueChanged"/>
                                    <DockPanel Grid.Row="4" Grid.Column="0">
                                        <Label Content="Дней между боями" Padding="5,2" DockPanel.Dock="Left"/>
                                        <TextBlock x:Name="TxtTournamentInterval" Text="7" DockPanel.Dock="Right"
                                                   HorizontalAlignment="Right" VerticalAlignment="Center"
                                                   Margin="0,0,0,0" Style="{StaticResource ValueText}"/>
                                    </DockPanel>
                                    <Slider Grid.Row="4" Grid.Column="1" x:Name="SldTournamentInterval"
                                            Minimum="3" Maximum="30" Value="7"
                                            TickFrequency="1" IsSnapToTickEnabled="True"
                                            ValueChanged="Slider_ValueChanged"/>
                                    <CheckBox Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2"
                                              x:Name="ChkTournamentSaveArmy"
                                              Content="Сохранять всю армию после боя"
                                              IsChecked="True"
                                              Visibility="Collapsed"
                                              Checked="ChkOption_Changed"
                                              Unchecked="ChkOption_Changed"/>
                                                </Grid>

                                <TextBlock Text="◆ ОКРУЖЕНИЕ И ВСТРЕЧИ" Margin="0,16,0,6"
                                           FontWeight="Bold" Opacity="0.85"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="210"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
