<Window x:Class="Olden_Era___Template_Editor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Olden_Era___Template_Editor.Models"
        mc:Ignorable="d"
        Title="AuroraRMG"
        Icon="pack://application:,,,/favicon.ico"
        Height="820" Width="1240"
        MinHeight="780" MinWidth="1160"
        WindowStyle="None"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        StateChanged="Window_StateChanged"
        Loaded="Window_Loaded"
        Background="#0E1117"
        FontFamily="Segoe UI, Arial, sans-serif">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="46"
                      ResizeBorderThickness="5"
                      GlassFrameThickness="0,0,0,1"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.InputBindings>
        <KeyBinding Key="N" Modifiers="Ctrl"       Command="{x:Static ApplicationCommands.New}"/>
        <KeyBinding Key="O" Modifiers="Ctrl"       Command="{x:Static ApplicationCommands.Open}"/>
        <KeyBinding Key="S" Modifiers="Ctrl"       Command="{x:Static ApplicationCommands.Save}"/>
        <KeyBinding Key="S" Modifiers="Ctrl+Shift" Command="{x:Static ApplicationCommands.SaveAs}"/>
    </Window.InputBindings>
    <Window.CommandBindings>
        <CommandBinding Command="{x:Static ApplicationCommands.New}"    Executed="BtnNew_Click"/>
        <CommandBinding Command="{x:Static ApplicationCommands.Open}"   Executed="BtnOpen_Click"/>
        <CommandBinding Command="{x:Static ApplicationCommands.Save}"   Executed="BtnSave_Click"/>
        <CommandBinding Command="{x:Static ApplicationCommands.SaveAs}" Executed="BtnSaveAs_Click"/>
    </Window.CommandBindings>

    <!-- Hidden combo boxes required by code-behind -->
    <Window.Resources>
        <Style x:Key="RowSpacer" TargetType="RowDefinition">
            <Setter Property="Height" Value="8"/>
        </Style>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <!-- Outer border gives the window its themed frame -->
    <Border BorderBrush="{StaticResource BrushBorder}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="46"/>    <!-- command header bar -->
                <RowDefinition Height="1"/>     <!-- divider -->
                <RowDefinition Height="*"/>     <!-- page content -->
            </Grid.RowDefinitions>

            <!-- ════════ COMMAND HEADER BAR ══════════════════════════════ -->
            <Grid Grid.Row="0" Background="#12151D">
                <!-- Brand + title (drag region) -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0,0,0"
                            HorizontalAlignment="Left"
                            MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Image Source="pack://application:,,,/favicon.ico" Width="22" Height="22"
                           VerticalAlignment="Center" Margin="0,0,10,0"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                    <!-- Wordmark: Aurora + RMG (cyan) -->
                    <TextBlock VerticalAlignment="Center">
                        <Run Text="Aurora" FontSize="15" FontWeight="Bold"
                             Foreground="{StaticResource BrushText}"/><Run Text="RMG" FontSize="15" FontWeight="Bold"
                             Foreground="{StaticResource BrushCyan}"/>
                    </TextBlock>
                    <!-- Version badge (target for auto-update display) -->
                    <Border CornerRadius="6" Padding="7,1" Margin="10,0,0,0"
                            VerticalAlignment="Center"
                            Background="#1B2236"
                            BorderBrush="{StaticResource BrushGoldDim}" BorderThickness="1">
                        <TextBlock x:Name="TxtVersionBadge"
                                   FontSize="10.5" FontWeight="SemiBold"
                                   Foreground="{StaticResource BrushGold}"
                                   VerticalAlignment="Center" Text="v0.0"/>
                    </Border>
                    <!-- Separator -->
                    <Border Width="1" Height="16" Background="{StaticResource BrushBorder}"
                            Margin="12,0,0,0" VerticalAlignment="Center"/>
                    <!-- Current file (secondary, dimmed) -->
                    <TextBlock x:Name="TxtWindowTitle"
                               FontSize="11.5"
                               Foreground="{StaticResource BrushTextDim}"
                               VerticalAlignment="Center" Margin="12,1,0,0"/>
                </StackPanel>

                <!-- File actions · links · window buttons (right) -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Stretch">

                    <!-- File actions (relocated from the old toolbar) -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,6,0"
                                WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button Content="🔄" Width="38" Margin="0,0,4,0" Click="BtnNew_Click"    Style="{StaticResource ToolbarButton}" ToolTip="{DynamicResource S.M.001}"/>
                        <Button Content="📂" Width="38" Margin="0,0,4,0" Click="BtnOpen_Click"   Style="{StaticResource ToolbarButton}" ToolTip="{DynamicResource S.M.002}"/>
                        <Button Content="💾" Width="38" Margin="0,0,4,0" Click="BtnSave_Click"   Style="{StaticResource ToolbarButton}" ToolTip="{DynamicResource S.M.003}"/>
                        <Button Content="💾…" Width="44" Margin="0,0,8,0" Click="BtnSaveAs_Click" Style="{StaticResource ToolbarButton}" ToolTip="{DynamicResource S.M.004}"/>
                        <Border Width="1" Background="{StaticResource BrushBorder}" Margin="0,4,8,4" VerticalAlignment="Stretch"/>
                        <!-- Simple / Advanced mode toggle -->
                        <Button x:Name="BtnModeSimple" Content="{DynamicResource S.Mode.Simple}" Tag="simple"
                                Margin="0,0,2,0" Click="BtnMode_Click" Style="{StaticResource ToolbarButton}"/>
                        <Button x:Name="BtnModeAdvanced" Content="{DynamicResource S.Mode.Advanced}" Tag="advanced"
                                Margin="0,0,8,0" Click="BtnMode_Click" Style="{StaticResource ToolbarButton}"/>
                        <Border Width="1" Background="{StaticResource BrushBorder}" Margin="0,4,8,4" VerticalAlignment="Stretch"/>
                        <Button x:Name="BtnLangRu" Content="RU" Width="34" Margin="0,0,2,0" Click="BtnLang_Click" Tag="ru" Style="{StaticResource ToolbarButton}" ToolTip="{DynamicResource S.M.006}"/>
                        <Button x:Name="BtnLangEn" Content="EN" Width="34" Click="BtnLang_Click" Tag="en" Style="{StaticResource ToolbarButton}" ToolTip="English language"/>
                    </StackPanel>

                    <Border Width="1" Background="{StaticResource BrushBorder}" Margin="8,11" VerticalAlignment="Stretch"/>

                    <!-- Window caption buttons -->
                    <Button Content="🗕" Style="{StaticResource TitleBarButton}"
                            ToolTip="{DynamicResource S.M.007}" Click="BtnMinimize_Click"/>
                    <Button x:Name="BtnMaximize" Content="🗖" Style="{StaticResource TitleBarButton}"
                            ToolTip="{DynamicResource S.M.008}" Click="BtnMaximize_Click"/>
                    <Button Content="✕" Style="{StaticResource TitleBarCloseButton}"
                            ToolTip="{DynamicResource S.M.009}" Click="BtnClose_Click"/>
                </StackPanel>
            </Grid>

            <!-- Gold divider line under title bar -->
            <Rectangle Grid.Row="1" Fill="{StaticResource BrushBorder}"/>

            <!-- ════════ PAGE CONTENT ═══════════════════════════════════ -->
            <Grid Grid.Row="2" Margin="14,10,14,12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- WIP warning -->
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="*"/>     <!-- main content -->
                </Grid.RowDefinitions>

                <!-- ════════ STATUS BANNERS (update + WIP) ═════════════════════ -->
                <StackPanel Grid.Row="0">

                    <!-- Auto-update banner (hidden until a newer release is found) -->
                    <Border x:Name="UpdateBanner" Visibility="Collapsed"
                            Background="#16213A"
                            BorderBrush="{StaticResource BrushGold}"
                            BorderThickness="1" CornerRadius="8"
                            Padding="12,8" Margin="0,0,0,8">
                        <DockPanel LastChildFill="True">
                            <TextBlock Text="✨" FontSize="14" VerticalAlignment="Center"
                                       Margin="0,0,10,0" DockPanel.Dock="Left"/>
                            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right"
                                        VerticalAlignment="Center" Margin="10,0,0,0">
                                <Button x:Name="BtnUpdateNow" Content="{DynamicResource S.M.010}"
                                        Style="{StaticResource GenerateButton}"
                                        Height="30" MinWidth="104" FontSize="13"
                                        Click="BtnUpdateNow_Click"/>
                                <Button x:Name="BtnUpdateNotes" Content="{DynamicResource S.M.011}"
                                        Margin="8,0,0,0" Height="30" MinWidth="96"
                                        Click="BtnUpdateNotes_Click"/>
                                <Button x:Name="BtnUpdateDismiss" Content="{DynamicResource S.M.012}"
                                        Margin="8,0,0,0" Height="30" MinWidth="72"
                                        Click="BtnUpdateDismiss_Click"/>
                            </StackPanel>
                            <TextBlock x:Name="TxtUpdateBanner"
                                       VerticalAlignment="Center" TextWrapping="Wrap"
                                       Foreground="{StaticResource BrushText}" FontSize="12"/>
                        </DockPanel>
                    </Border>

                    <!-- WIP warning -->
                    <Border Background="{StaticResource BrushWarnBg}"
                            BorderBrush="{StaticResource BrushWarnBorder}"
                            BorderThickness="1" CornerRadius="8"
                            Padding="12,8">
                        <TextBlock x:Name="TxtWipWarning"
                                   Foreground="{StaticResource BrushWarnText}"
                                   FontSize="11" TextWrapping="Wrap"/>
                    </Border>
                </StackPanel>

        <!-- ════════ MAIN CONTENT — mode toggle + (Simple | Advanced) views ════ -->
        <DockPanel Grid.Row="2" LastChildFill="True">

            <!-- View host: exactly one of AdvancedView / SimpleView is visible.
                 The Simple/Advanced toggle lives in the top command bar (next to RU/EN). -->
            <Grid>

            <Grid x:Name="AdvancedView">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="290"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
            <TabControl x:Name="MainTabs"
                        TabStripPlacement="Top"
                        ItemContainerStyle="{StaticResource TopTab}"
                        KeyboardNavigation.TabNavigation="Cycle"
                        VerticalContentAlignment="Stretch">
                <TabItem Header="{DynamicResource S.Tab.Rules}" Tag="{StaticResource BrushTabRules}">
                <Grid Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="0.9*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="1.1*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- 1st row -->
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>  <!-- 2nd row -->
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="*"/>     <!-- 3rd row -->
                </Grid.RowDefinitions>

                <!-- HEROES (left) -->
                <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource SectionBorder}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource S.Hdr.Heroes}" Style="{StaticResource SectionHeader}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="168"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="6"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="6"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Начальный лимит героев -->
                            <Label Grid.Row="0" Grid.Column="0" Content="{DynamicResource S.Lbl.HeroMin}"
                                   Padding="5,2" VerticalAlignment="Center"/>
                            <Slider Grid.Row="0" Grid.Column="1" x:Name="SldHeroMin"
                                    Minimum="1" Maximum="12" Value="4" VerticalAlignment="Center"
                                    Margin="0,0,6,0" TickFrequency="1" IsSnapToTickEnabled="True"
                                    ValueChanged="Slider_ValueChanged"/>
                            <StackPanel Grid.Row="0" Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button Content="−" Width="22" Style="{StaticResource ToolbarButton}"
                                        Tag="-SldHeroMin" Click="HeroStep_Click" ToolTip="{DynamicResource S.M.016}"/>
                                <TextBox x:Name="TxtHeroMin" Text="4" Width="34" MaxLength="3"
                                         TextAlignment="Center" VerticalContentAlignment="Center" Margin="2,0"
                                         ToolTip="{DynamicResource S.M.017}"
                                         LostFocus="HeroBox_LostFocus" KeyDown="HeroBox_KeyDown"/>
                                <Button Content="+" Width="22" Style="{StaticResource ToolbarButton}"
                                        Tag="+SldHeroMin" Click="HeroStep_Click" ToolTip="{DynamicResource S.M.018}"/>
                            </StackPanel>

                            <!-- Прирост лимита за замок (между начальным и максимумом) -->
                            <Label Grid.Row="2" Grid.Column="0" Content="{DynamicResource S.Lbl.HeroIncrement}"
                                   Padding="5,2" VerticalAlignment="Center"/>
                            <Slider Grid.Row="2" Grid.Column="1" x:Name="SldHeroIncrement"
                                    Minimum="0" Maximum="20" Value="1" VerticalAlignment="Center"
                                    Margin="0,0,6,0" TickFrequency="1" IsSnapToTickEnabled="True"
                                    ValueChanged="Slider_ValueChanged"/>
                            <StackPanel Grid.Row="2" Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button Content="−" Width="22" Style="{StaticResource ToolbarButton}"
                                        Tag="-SldHeroIncrement" Click="HeroStep_Click" ToolTip="{DynamicResource S.M.016}"/>
                                <TextBox x:Name="TxtHeroIncrement" Text="1" Width="34" MaxLength="3"
                                         TextAlignment="Center" VerticalContentAlignment="Center" Margin="2,0"
                                         ToolTip="{DynamicResource S.M.017}"
                                         LostFocus="HeroBox_LostFocus" KeyDown="HeroBox_KeyDown"/>
                                <Button Content="+" Width="22" Style="{StaticResource ToolbarButton}"
                                        Tag="+SldHeroIncrement" Click="HeroStep_Click" ToolTip="{DynamicResource S.M.018}"/>
                            </StackPanel>

                            <!-- Максимальный лимит героев (внизу) -->
                            <Label Grid.Row="4" Grid.Column="0" Content="{DynamicResource S.Lbl.HeroMax}"
                                   Padding="5,2" VerticalAlignment="Center"/>
                            <Slider Grid.Row="4" Grid.Column="1" x:Name="SldHeroMax"
                                    Minimum="1" Maximum="12" Value="8" VerticalAlignment="Center"
                                    Margin="0,0,6,0" TickFrequency="1" IsSnapToTickEnabled="True"
                                    ValueChanged="Slider_ValueChanged"/>
                            <StackPanel Grid.Row="4" Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button Content="−" Width="22" Style="{StaticResource ToolbarButton}"
                                        Tag="-SldHeroMax" Click="HeroStep_Click" ToolTip="{DynamicResource S.M.016}"/>
                                <TextBox x:Name="TxtHeroMax" Text="8" Width="34" MaxLength="3"
                                         TextAlignment="Center" VerticalContentAlignment="Center" Margin="2,0"
                                         ToolTip="{DynamicResource S.M.017}"
                                         LostFocus="HeroBox_LostFocus" KeyDown="HeroBox_KeyDown"/>
                                <Button Content="+" Width="22" Style="{StaticResource ToolbarButton}"
                                        Tag="+SldHeroMax" Click="HeroStep_Click" ToolTip="{DynamicResource S.M.018}"/>
                            </StackPanel>
                        </Grid>

                        <!-- Запрет найма героев (heroHireBan) -->
                        <CheckBox x:Name="ChkHeroHireBan" Content="{DynamicResource S.Chk.HeroHireBan}"
                                  Margin="5,12,5,2" VerticalContentAlignment="Center"
                                  ToolTip="{DynamicResource S.Tip.HeroHireBan}"
                                  Checked="ChkOption_Changed" Unchecked="ChkOption_Changed"/>
                        <!-- Поражение при потере стартового героя (перенесено из Правил) -->
                        <CheckBox x:Name="ChkLostStartHero" Content="{DynamicResource S.M.024}"
                                  Margin="5,4,5,2" VerticalContentAlignment="Center"
                                  Checked="WinConditionOption_Changed" Unchecked="WinConditionOption_Changed"/>
                        <!-- Переход к списку банов героев -->
                        <Button x:Name="BtnUnwantedHeroes" Content="{DynamicResource S.Btn.UnwantedHeroes}"
                                Margin="5,10,5,2" HorizontalAlignment="Left" Padding="12,5"
                                Style="{StaticResource ToolbarButton}" Click="BtnUnwantedHeroes_Click"
                                ToolTip="{DynamicResource S.Tip.UnwantedHeroes}"/>
                    </StackPanel>
                    </ScrollViewer>
                </Border>

                <!-- TEMPLATE (right, wider) -->
                <Border Grid.Row="0" Grid.Column="2" Style="{StaticResource SectionBorder}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource S.Hdr.Template}" Style="{StaticResource SectionHeader}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="155"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Игроки (наверху) -->
                            <DockPanel Grid.Row="0" Grid.Column="0">
                                <Label Content="{DynamicResource S.Lbl.Players}" DockPanel.Dock="Left"/>
                                <TextBlock x:Name="TxtPlayers" Text="2" DockPanel.Dock="Right"
                                           HorizontalAlignment="Right" VerticalAlignment="Center"
                                           Margin="0,0,4,0" Style="{StaticResource ValueText}"/>
                            </DockPanel>
                            <Slider Grid.Row="0" Grid.Column="1" x:Name="SldPlayers"
                                    Minimum="2" Maximum="8" Value="2"
                                    TickFrequency="1" IsSnapToTickEnabled="True"
                                    ValueChanged="Slider_ValueChanged"/>

                            <!-- Вид карты (дублирует топологию из вкладки "Настройка зон") -->
                            <Label Grid.Row="2" Grid.Column="0" Content="{DynamicResource S.Lbl.MapView}"/>
                            <ComboBox Grid.Row="2" Grid.Column="1" x:Name="CmbMapView"
                                      SelectionChanged="CmbMapView_SelectionChanged"/>

                            <!-- Размер карты -->
                            <Label Grid.Row="4" Grid.Column="0" Content="{DynamicResource S.Lbl.MapSize}"/>
                            <ComboBox x:Name="CmbMapSize" Grid.Row="4" Grid.Column="1" SelectionChanged="CmbMapSize_SelectionChanged"/>
                            <StackPanel Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2">
                                <CheckBox x:Name="ChkExperimentalMapSizes"
                                          Content="{DynamicResource S.Chk.ExpMaps}"
                                          Foreground="{StaticResource BrushCyan}"
                                          FontWeight="SemiBold"
                                          Margin="0,4,0,0"
                                          ToolTip="{DynamicResource S.CB.V.ExpSize}"
                                          Checked="ChkExperimentalMapSizes_Changed"
                                          Unchecked="ChkExperimentalMapSizes_Changed"/>
                                <TextBlock x:Name="TxtExperimentalMapSizeWarning"
                                           Foreground="{StaticResource BrushTextDim}"
                                           FontSize="11" TextWrapping="Wrap" Margin="0,4,0,0"
                                           Visibility="Collapsed" Text="{DynamicResource S.M.015}"/>
                            </StackPanel>

                            <!-- Пресет (+ кнопка случайного подбора под число игроков) -->
                            <Label Grid.Row="8" Grid.Column="0" Content="{DynamicResource S.Lbl.Preset}" VerticalAlignment="Center"/>
                            <DockPanel Grid.Row="8" Grid.Column="1">
                                <Button x:Name="BtnRandomPreset" DockPanel.Dock="Right" Content="🎲"
                                        Width="34" Margin="6,0,0,0" Click="BtnRandomPreset_Click"
                                        Style="{StaticResource ToolbarButton}"
                                        ToolTip="{DynamicResource S.Tip.Random}"/>
                                <Button x:Name="BtnPreset" Click="BtnPreset_Click"
                                        Content="{DynamicResource S.Btn.PresetPick}"
                                        HorizontalContentAlignment="Left"
                                        Style="{StaticResource ToolbarButton}"
                                        ToolTip="{DynamicResource S.M.013}"/>
                            </DockPanel>

                            <!-- Название шаблона (в самом конце) -->
                            <Label Grid.Row="10" Grid.Column="0" Content="{DynamicResource S.Lbl.TemplateName}"/>
                            <TextBox Grid.Row="10" Grid.Column="1" x:Name="TxtTemplateName" Text="{DynamicResource S.M.014}"/>
                        </Grid>
                    </StackPanel>
                    </ScrollViewer>
                </Border>

                <!-- ADVANCED GAME RULES -->
                <Border Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3" x:Name="PnlAdvancedGameRules" Style="{StaticResource SectionBorder}">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="{DynamicResource S.Hdr.GameRules}" Style="{StaticResource SectionHeader}"/>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel>
                            <!-- Условия победы (наверху) + режим одного героя + опыт/дипломатия -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="205"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>   <!-- условие победы -->
                                    <RowDefinition Height="6"/>
                                    <RowDefinition Height="Auto"/>   <!-- режим одного героя -->
                                    <RowDefinition Height="12"/>
                                    <RowDefinition Height="Auto"/>   <!-- законы -->
                                    <RowDefinition Height="10"/>
                                    <RowDefinition Height="Auto"/>   <!-- астрология -->
                                    <RowDefinition Height="10"/>
                                    <RowDefinition Height="Auto"/>   <!-- дипломатия -->
                                </Grid.RowDefinitions>

                                <Label Grid.Row="0" Grid.Column="0" Content="{DynamicResource S.M.019}" VerticalAlignment="Center"/>
                                <ComboBox Grid.Row="0" Grid.Column="1" x:Name="CmbVictory"
                                          SelectionChanged="CmbVictory_SelectionChanged"/>

                                <CheckBox Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                                          x:Name="ChkSingleHeroMode" Content="{DynamicResource S.Chk.SingleHero}"
                                          VerticalContentAlignment="Center"
                                          Checked="ChkSingleHeroMode_Changed" Unchecked="ChkSingleHeroMode_Changed"/>

                                <DockPanel Grid.Row="4" Grid.Column="0">
                                    <Label Content="{DynamicResource S.M.020}" DockPanel.Dock="Left"/>
                                    <TextBlock x:Name="TxtFactionLawsExp" Text="100%" DockPanel.Dock="Right"
                                               HorizontalAlignment="Right" VerticalAlignment="Center"
                                               Margin="0,0,10,0" Style="{StaticResource ValueText}"/>
                                </DockPanel>
                                <Slider Grid.Row="4" Grid.Column="1" x:Name="SldFactionLawsExp"
                                        Minimum="20" Maximum="200" Value="100"
                                        TickFrequency="10" SmallChange="10" IsSnapToTickEnabled="True"
                                        ValueChanged="Slider_ValueChanged"/>

                                <DockPanel Grid.Row="6" Grid.Column="0">
                                    <Label Content="{DynamicResource S.M.021}" DockPanel.Dock="Left"/>
                                    <TextBlock x:Name="TxtAstrologyExp" Text="100%" DockPanel.Dock="Right"
                                               HorizontalAlignment="Right" VerticalAlignment="Center"
                                               Margin="0,0,10,0" Style="{StaticResource ValueText}"/>
                                </DockPanel>
                                <Slider Grid.Row="6" Grid.Column="1" x:Name="SldAstrologyExp"
                                        Minimum="20" Maximum="200" Value="100"
                                        TickFrequency="10" SmallChange="10" IsSnapToTickEnabled="True"
                                        ValueChanged="Slider_ValueChanged"/>

                                <DockPanel Grid.Row="8" Grid.Column="0">
                                    <Label Content="{DynamicResource S.M.038}" DockPanel.Dock="Left"/>
                                    <TextBlock x:Name="TxtDiplomacy" Text="-0.50" DockPanel.Dock="Right"
                                               HorizontalAlignment="Right" VerticalAlignment="Center"
                                               Margin="0,0,10,0" Style="{StaticResource ValueText}"/>
                                </DockPanel>
                                <Slider Grid.Row="8" Grid.Column="1" x:Name="SldDiplomacy"
                                        Minimum="-100" Maximum="100" Value="-50"
                                        TickFrequency="5" SmallChange="5" IsSnapToTickEnabled="True"
                                        ValueChanged="Slider_ValueChanged"/>
                            </Grid>

                            <StackPanel Margin="0,10,0,0">
                                <CheckBox x:Name="ChkLostStartCity"
                                          Content="{DynamicResource S.M.022}"
                                          Checked="WinConditionOption_Changed"
                                          Unchecked="WinConditionOption_Changed"/>
                                <Grid x:Name="PnlLostStartCityDetails" Margin="18,3,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="167"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <DockPanel Grid.Column="0">
                                        <Label Content="{DynamicResource S.M.023}" Padding="5,2" DockPanel.Dock="Left"/>
                                        <TextBlock x:Name="TxtLostStartCityDay" Text="3" DockPanel.Dock="Right"
                                                   HorizontalAlignment="Right" VerticalAlignment="Center"
                                                   Margin="0,0,0,0" Style="{StaticResource ValueText}"/>
                                    </DockPanel>
                                    <Slider Grid.Column="1" x:Name="SldLostStartCityDay"
                                            Minimum="1" Maximum="30" Value="3"
                                            TickFrequency="1" IsSnapToTickEnabled="True"
                                            ValueChanged="Slider_ValueChanged"/>
                                </Grid>

                                <CheckBox x:Name="ChkCityHold"
                                          Content="{DynamicResource S.M.025}"
                                          Margin="0,6,0,0"
                                          Checked="WinConditionOption_Changed"
                                          Unchecked="WinConditionOption_Changed"/>
                                <Grid x:Name="PnlCityHoldDetails" Margin="18,3,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="167"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <DockPanel Grid.Column="0">
                                        <Label Content="{DynamicResource S.M.026}" Padding="5,2" DockPanel.Dock="Left"/>
                                        <TextBlock x:Name="TxtCityHoldDays" Text="6" DockPanel.Dock="Right"
                                                   HorizontalAlignment="Right" VerticalAlignment="Center"
