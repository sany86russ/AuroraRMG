                           Text="⚠️ Настройки изменились — создайте новый шаблон перед сохранением, чтобы применить изменения."/>

                <Button Grid.Row="10"
                        x:Name="BtnSaveGenerated"
                        Content="💾  Сохранить шаблон"
                        Style="{StaticResource GenerateButton}"
                        Visibility="Visible"
                        IsEnabled="False"
                        Click="BtnSaveGenerated_Click"/>
            </Grid>

