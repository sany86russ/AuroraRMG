            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>   <!-- generate button -->
                    <RowDefinition Height="6"/>
                    <RowDefinition Height="Auto"/>   <!-- hints / validation -->
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="*"/>      <!-- image -->
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>   <!-- outdated warning -->
                    <RowDefinition Height="6"/>
                    <RowDefinition Height="Auto"/>   <!-- show preview checkbox -->
                    <RowDefinition Height="6"/>
                    <RowDefinition Height="Auto"/>   <!-- save button -->
                </Grid.RowDefinitions>

                <Button Grid.Row="0"
                        x:Name="BtnPreview"
                        Content="⚔  Создать шаблон"
                        Style="{StaticResource GenerateButton}"
                        Click="BtnPreview_Click"/>

                <ScrollViewer Grid.Row="2"
                              x:Name="PnlValidation"
                              Visibility="Collapsed"
                              MaxHeight="120"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl x:Name="LstValidation" Margin="4,2">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="•"
                                               Foreground="{Binding Foreground}"
                                               FontSize="12"
                                               VerticalAlignment="Top"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Text}"
                                               Foreground="{Binding Foreground}"
                                               FontSize="12"
                                               TextWrapping="Wrap"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
                        
                        <Border Grid.Row="4"
                        BorderThickness="2"
                        CornerRadius="4"
                        BorderBrush="{StaticResource BrushBorder}"
                        Background="#0E1117">
                            <StackPanel VerticalAlignment="Center"
                            HorizontalAlignment="Center"> 
                                <Label x:Name="lblNoPreview" Visibility="Collapsed" FontSize="172"></Label>
                                <Image x:Name="ImgPreview"
                                Stretch="Uniform"
                                RenderOptions.BitmapScalingMode="HighQuality"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center"/>
                            </StackPanel>
                            
                        </Border>

                <CheckBox Grid.Row="8"
                          x:Name="ChkSavePreviewImage"
                          Content="Показать превью"
                          IsChecked="True"
                          Visibility="Visible"
                          Foreground="{StaticResource BrushText}"
                          HorizontalAlignment="Left" Click="ChkSavePreviewImage_Click" />

