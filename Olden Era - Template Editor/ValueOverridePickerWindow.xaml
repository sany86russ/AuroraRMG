<Window x:Class="Olden_Era___Template_Editor.ValueOverridePickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Переопределение значений" Width="560" Height="660"
        Icon="pack://application:,,,/favicon.ico"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        MinWidth="400" MinHeight="390"
        WindowStyle="None"
        Background="#0E1117"
        Foreground="#E7EBF3"
        FontFamily="Segoe UI" FontSize="13">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32" ResizeBorderThickness="5"
                      GlassFrameThickness="0,0,0,1" UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Border BorderBrush="{StaticResource BrushBorder}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="32"/>
                <RowDefinition Height="1"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Grid Grid.Row="0" Background="#12151D">
                <TextBlock Text="Переопределение значений"
                           FontSize="12" FontWeight="SemiBold"
                           Foreground="{StaticResource BrushText}"
                           VerticalAlignment="Center" Margin="10,0,0,0"
                           MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"/>
                <Button Content="✕" Style="{StaticResource TitleBarCloseButton}"
                        HorizontalAlignment="Right"
                        ToolTip="Закрыть" Click="BtnClose_Click"/>
            </Grid>

            <!-- Gold divider -->
            <Rectangle Grid.Row="1" Fill="{StaticResource BrushBorder}"/>

            <!-- Content -->
            <DockPanel Grid.Row="2" Margin="12" Background="{StaticResource BrushPanel}">

                <!-- Search box -->
                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                    <TextBox x:Name="TxtSearch"
                             TextChanged="TxtSearch_TextChanged"
                             Height="28"/>
                </StackPanel>

                <!-- Guard value row -->
                <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="120"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Сила охраны для выбранных:"
                               VerticalAlignment="Center" Margin="0,0,8,0"
                               Foreground="{StaticResource BrushTextDim}" FontSize="12"/>
                    <TextBox Grid.Column="1" x:Name="TxtGuardValue"
                             Height="26" Text="5000"
                             FontFamily="Consolas" FontSize="12"
                             ToolTip="Сила охраны для всех отмеченных объектов"/>
                </Grid>

                <!-- Buttons (bottom) -->
                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                            HorizontalAlignment="Right" Margin="0,8,0,0">
                    <Button x:Name="BtnAdd" Content="Добавить выбранное"
                            Width="120" Height="28" Margin="0,0,8,0"
                            IsDefault="True"
                            Click="BtnAdd_Click"/>
                    <Button Content="Отмена"
                            Width="80" Height="28"
                            IsCancel="True"
                            Click="BtnCancel_Click"/>
                </StackPanel>

                <!-- Object SID list -->
                <ListBox x:Name="LbSids"
                         PreviewMouseLeftButtonDown="LbSids_PreviewMouseLeftButtonDown"
                         Background="{StaticResource BrushInput}"
                         Foreground="{StaticResource BrushText}"
                         BorderBrush="{StaticResource BrushBorder}" BorderThickness="1">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding"    Value="4,3"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border Background="{TemplateBinding Background}"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="ChkMark" Text="" Width="16"
                                           Foreground="{StaticResource BrushGold}" FontWeight="Bold"
                                           VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <TextBlock Text="{Binding}"
                                           FontFamily="Consolas" FontSize="12"
                                           Foreground="{StaticResource BrushText}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

            </DockPanel>
        </Grid>
    </Border>
</Window>
