<Window x:Class="Olden_Era___Template_Editor.TemplateEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource S.Ed.001}"
        Height="820" Width="1200"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BrushPanel}"
        UseLayoutRounding="True"
        KeyDown="Window_KeyDown">
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Background="{StaticResource BrushPanelAlt}" Padding="10,7"
                BorderBrush="{StaticResource BrushBorder}" BorderThickness="0,0,0,1">
            <DockPanel LastChildFill="False">
                <TextBlock Text="{DynamicResource S.Ed.001}" Foreground="{StaticResource BrushGold}"
                           FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center"
                           Margin="0,0,16,0" DockPanel.Dock="Left"/>
                <Button x:Name="BtnLoad" Content="{DynamicResource S.Ed.002}" DockPanel.Dock="Left"
                        Style="{StaticResource ToolbarButton}" Margin="0,0,8,0" Click="BtnLoad_Click"/>
                <Button x:Name="BtnAddZone" Content="{DynamicResource S.Ed.003}" DockPanel.Dock="Left"
                        Style="{StaticResource ToolbarButton}" Margin="0,0,8,0" Click="BtnAddZone_Click"/>
                <Button x:Name="BtnConnectMode" Content="{DynamicResource S.Ed.004}" DockPanel.Dock="Left"
                        Style="{StaticResource ToolbarButton}" Margin="0,0,8,0" Click="BtnConnectMode_Click"/>
                <Button x:Name="BtnDelete" Content="{DynamicResource S.Ed.005}" DockPanel.Dock="Left"
                        Style="{StaticResource ToolbarButton}" Margin="0,0,8,0" Click="BtnDelete_Click"/>
                <Button x:Name="BtnValidate" Content="{DynamicResource S.Ed.006}" DockPanel.Dock="Left"
                        Style="{StaticResource ToolbarButton}" Margin="0,0,8,0" Click="BtnValidate_Click"/>
                <Button x:Name="BtnSave" Content="{DynamicResource S.Ed.007}" DockPanel.Dock="Left"
                        Style="{StaticResource ToolbarButton}" Margin="0,0,8,0" Click="BtnSave_Click"/>
                <Button x:Name="BtnExportPng" Content="{DynamicResource S.Ed.ExportPng}" DockPanel.Dock="Left"
                        Style="{StaticResource ToolbarButton}" Margin="0,0,8,0" Click="BtnExportPng_Click"/>

                <Button x:Name="BtnZoomReset" Content="{DynamicResource S.Ed.008}" DockPanel.Dock="Right"
                        Style="{StaticResource ToolbarButton}" Click="BtnZoomReset_Click"/>
                <Button x:Name="BtnRelayout" Content="{DynamicResource S.Ed.009}" DockPanel.Dock="Right" Margin="0,0,8,0"
                        Style="{StaticResource ToolbarButton}" Click="BtnRelayout_Click"/>
                <Button x:Name="BtnZoomIn" Content="+" Width="30" DockPanel.Dock="Right" Margin="0,0,4,0"
                        Style="{StaticResource ToolbarButton}" Click="BtnZoomIn_Click" ToolTip="{DynamicResource S.Ed.ZoomIn}"/>
                <Button x:Name="BtnZoomOut" Content="−" Width="30" DockPanel.Dock="Right" Margin="0,0,8,0"
                        Style="{StaticResource ToolbarButton}" Click="BtnZoomOut_Click" ToolTip="{DynamicResource S.Ed.ZoomOut}"/>
            </DockPanel>
        </Border>

        <!-- Grid snap toggle (floating, under editor icon) -->
        <Button x:Name="BtnGridSnap" Grid.Row="0"
                HorizontalAlignment="Left" VerticalAlignment="Bottom"
                Margin="12,-30,0,0" Panel.ZIndex="10"
                Style="{StaticResource ToolbarButton}"
                Content="{DynamicResource S.EC.GridSnap}"
                Click="BtnGridSnap_Click"
                ToolTip="{DynamicResource S.EC.GridSnapTip}"/>

        <!-- Body: canvas + inspector -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>

            <!-- Canvas host (graph + floating legend) -->
            <Border Grid.Column="0" ClipToBounds="True" Background="#0E0B16"
                    x:Name="CanvasHost" Focusable="True"
                    MouseWheel="CanvasHost_MouseWheel"
                    MouseLeftButtonDown="CanvasHost_MouseLeftButtonDown"
                    MouseMove="CanvasHost_MouseMove"
                    MouseLeftButtonUp="CanvasHost_MouseLeftButtonUp">
                <Grid>
                    <Canvas x:Name="GraphCanvas" Width="700" Height="700"
                            HorizontalAlignment="Left" VerticalAlignment="Top">
                        <Canvas.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform x:Name="CanvasScale" ScaleX="1" ScaleY="1"/>
                                <TranslateTransform x:Name="CanvasTranslate" X="0" Y="0"/>
                            </TransformGroup>
                        </Canvas.RenderTransform>
                    </Canvas>

                    <!-- Floating legend (not transformed) -->
                    <Border HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="12"
                            Background="#CC12161F" BorderBrush="{StaticResource BrushBorder}"
                            BorderThickness="1" CornerRadius="6" Padding="10,8" IsHitTestVisible="False">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource S.Ed.LegZones}" Foreground="{StaticResource BrushTextDim}" FontSize="11" Margin="0,0,0,4"/>
                            <StackPanel Orientation="Horizontal" Margin="0,1">
                                <Ellipse Width="10" Height="10" Fill="#5EB36E" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                <TextBlock Text="player_spawn" Foreground="{StaticResource BrushText}" FontSize="11" VerticalAlignment="Center"/>
                                <Ellipse Width="10" Height="10" Fill="#5080A0" Margin="12,0,5,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Hub" Foreground="{StaticResource BrushText}" FontSize="11" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,1">
                                <Ellipse Width="10" Height="10" Fill="#1E4650" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                <TextBlock Text="ai_spawn" Foreground="{StaticResource BrushText}" FontSize="11" VerticalAlignment="Center"/>
                                <Ellipse Width="10" Height="10" Fill="#465A28" Margin="12,0,5,0" VerticalAlignment="Center"/>
                                <TextBlock Text="second_spawn" Foreground="{StaticResource BrushText}" FontSize="11" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,1">
                                <Ellipse Width="10" Height="10" Fill="#503C5A" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                <TextBlock Text="side_spawn_zone" Foreground="{StaticResource BrushText}" FontSize="11" VerticalAlignment="Center"/>
                                <Ellipse Width="10" Height="10" Fill="#464628" Margin="12,0,5,0" VerticalAlignment="Center"/>
                                <TextBlock Text="spawns" Foreground="{StaticResource BrushText}" FontSize="11" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,1">
                                <Ellipse Width="10" Height="10" Fill="#654321" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                <TextBlock Text="sides" Foreground="{StaticResource BrushText}" FontSize="11" VerticalAlignment="Center"/>
                                <Ellipse Width="10" Height="10" Fill="#82501E" Margin="12,0,5,0" VerticalAlignment="Center"/>
                                <TextBlock Text="side_zone" Foreground="{StaticResource BrushText}" FontSize="11" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,1">
                                <Ellipse Width="10" Height="10" Fill="#484C50" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                <TextBlock Text="treasure" Foreground="{StaticResource BrushText}" FontSize="11" VerticalAlignment="Center"/>
                                <Ellipse Width="10" Height="10" Fill="#5A5A6E" Margin="12,0,5,0" VerticalAlignment="Center"/>
                                <TextBlock Text="treasures" Foreground="{StaticResource BrushText}" FontSize="11" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,1">
                                <Ellipse Width="10" Height="10" Fill="#8C7814" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                <TextBlock Text="supertreasure_zone" Foreground="{StaticResource BrushText}" FontSize="11" VerticalAlignment="Center"/>
                                <Ellipse Width="10" Height="10" Fill="#785A14" Margin="12,0,5,0" VerticalAlignment="Center"/>
                                <TextBlock Text="center" Foreground="{StaticResource BrushText}" FontSize="11" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,1">
                                <Ellipse Width="10" Height="10" Fill="#96781E" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                <TextBlock Text="center_zone" Foreground="{StaticResource BrushText}" FontSize="11" VerticalAlignment="Center"/>
                                <Ellipse Width="10" Height="10" Fill="#284664" Margin="12,0,5,0" VerticalAlignment="Center"/>
                                <TextBlock Text="start_zone" Foreground="{StaticResource BrushText}" FontSize="11" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,1">
                                <Ellipse Width="10" Height="10" Fill="#3C305A" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                <TextBlock Text="back" Foreground="{StaticResource BrushText}" FontSize="11" VerticalAlignment="Center"/>
                                <Ellipse Width="10" Height="10" Fill="#326432" Margin="12,0,5,0" VerticalAlignment="Center"/>
                                <TextBlock Text="leaf" Foreground="{StaticResource BrushText}" FontSize="11" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,1">
                                <Ellipse Width="10" Height="10" Fill="#A06414" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                <TextBlock Text="wincondition_zone" Foreground="{StaticResource BrushText}" FontSize="11" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="{DynamicResource S.Ed.LegConns}" Foreground="{StaticResource BrushTextDim}" FontSize="11" Margin="0,6,0,4"/>
                            <StackPanel Orientation="Horizontal" Margin="0,1">
                                <Rectangle Width="18" Height="3" Fill="#B4913C" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Direct" Foreground="{StaticResource BrushText}" FontSize="11" VerticalAlignment="Center"/>
                                <Rectangle Width="18" Height="3" Fill="#A0A0A0" Margin="14,0,5,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Default" Foreground="{StaticResource BrushText}" FontSize="11" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,1">
                                <Rectangle Width="18" Height="2" Fill="#5AAAD2" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Portal" Foreground="{StaticResource BrushText}" FontSize="11" VerticalAlignment="Center"/>
                                <Rectangle Width="18" Height="2.5" Fill="#50C878" Margin="14,0,5,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Proximity" Foreground="{StaticResource BrushText}" FontSize="11" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,1">
                                <Rectangle Width="18" Height="2.5" Fill="#DC3C3C" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                <TextBlock Text="GladiatorArena" Foreground="{StaticResource BrushText}" FontSize="11" VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Hint (top-left) -->
                    <TextBlock x:Name="TxtCanvasHint" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="12,10"
                               Foreground="{StaticResource BrushTextDim}" FontSize="11" IsHitTestVisible="False"
                               Text="{DynamicResource S.Ed.CanvasHint}"/>
                </Grid>
            </Border>

            <!-- Inspector -->
            <Border Grid.Column="2" Background="{StaticResource BrushPanelAlt}"
                    BorderBrush="{StaticResource BrushBorder}" BorderThickness="1,0,0,0">
                <DockPanel>
                    <TextBlock x:Name="TxtInspectorHint" DockPanel.Dock="Top"
                               Foreground="{StaticResource BrushTextDim}" FontSize="11"
                               Margin="12,8,12,0"/>
                     <TabControl x:Name="InspectorTabs" DockPanel.Dock="Top"
                                 Background="Transparent" BorderThickness="0"
                                 Padding="0" Margin="0">
                         <TabControl.Template>
                             <ControlTemplate TargetType="TabControl">
                                 <Grid>
                                     <Grid.RowDefinitions>
                                         <RowDefinition Height="Auto"/>
                                         <RowDefinition Height="*"/>
                                     </Grid.RowDefinitions>
                                      <UniformGrid x:Name="HeaderPanel"
                                                   Grid.Row="0"
                                                   Rows="2"
                                                   Columns="3"
                                                   Panel.ZIndex="1"
                                                   Margin="0"
                                                   IsItemsHost="True"
                                                   Background="Transparent"/>
                                     <Border Grid.Row="1"
                                             Background="Transparent"
                                             BorderThickness="0">
                                         <ContentPresenter x:Name="PART_SelectedContentHost"
                                                           ContentSource="SelectedContent"/>
                                     </Border>
                                 </Grid>
                             </ControlTemplate>
                         </TabControl.Template>
                        <TabItem x:Name="TabMain" Header="{DynamicResource S.EC.TabMain}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12,10">
                                <StackPanel x:Name="InspectorFieldsMain" Margin="0,6,0,0"/>
                            </ScrollViewer>
                        </TabItem>
                        <TabItem x:Name="TabGuard" Header="{DynamicResource S.EC.TabGuard}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12,10">
                                <StackPanel x:Name="InspectorFieldsGuard" Margin="0,6,0,0"/>
                            </ScrollViewer>
                        </TabItem>
                        <TabItem x:Name="TabPools" Header="{DynamicResource S.EC.TabPools}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12,10">
                                <StackPanel x:Name="InspectorFieldsPools" Margin="0,6,0,0"/>
                            </ScrollViewer>
                        </TabItem>
                        <TabItem x:Name="TabContent" Header="{DynamicResource S.EC.TabContent}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12,10">
                                <StackPanel x:Name="InspectorFieldsContent" Margin="0,6,0,0"/>
                            </ScrollViewer>
                        </TabItem>
                         <TabItem x:Name="TabBiome" Header="{DynamicResource S.EC.TabBiome}">
                             <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12,10">
                                 <StackPanel x:Name="InspectorFieldsBiome" Margin="0,6,0,0"/>
                             </ScrollViewer>
                         </TabItem>
                         <TabItem x:Name="TabObjects" Header="{DynamicResource S.EC.TabObjects}">
                             <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12,10">
                                 <StackPanel x:Name="InspectorFieldsObjects" Margin="0,6,0,0"/>
                             </ScrollViewer>
                         </TabItem>
                     </TabControl>
                </DockPanel>
            </Border>
        </Grid>

        <!-- Status bar -->
        <Border Grid.Row="2" Background="{StaticResource BrushPanelAlt}"
                BorderBrush="{StaticResource BrushBorder}" BorderThickness="0,1,0,0" Padding="10,5">
            <DockPanel LastChildFill="False">
                <TextBlock x:Name="TxtStatus" DockPanel.Dock="Left"
                           Foreground="{StaticResource BrushTextDim}" FontSize="12"
                           Text="{DynamicResource S.Ed.012}"/>
                <TextBlock x:Name="TxtZoomLabel" DockPanel.Dock="Right"
                           Foreground="{StaticResource BrushTextDim}" FontSize="12"
                           Text="100%"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
