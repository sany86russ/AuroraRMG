<Window x:Class="Olden_Era___Template_Editor.ContentPoolCreatorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource S.PC.Title}"
        Height="700" Width="900"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BrushPanel}"
        UseLayoutRounding="True">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Pool name -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="{DynamicResource S.PC.PoolName}" Foreground="{StaticResource BrushTextDim}" FontSize="12" Margin="0,0,0,4"/>
            <TextBox x:Name="PoolNameBox" FontSize="12" Padding="4"/>
        </StackPanel>

        <!-- Search filter -->
        <StackPanel Grid.Row="1" Margin="0,0,0,8">
            <TextBlock Text="{DynamicResource S.PC.Search}" Foreground="{StaticResource BrushTextDim}" FontSize="12" Margin="0,0,0,4"/>
            <TextBox x:Name="SearchBox" FontSize="12" Padding="4" TextChanged="SearchBox_TextChanged"/>
        </StackPanel>

        <!-- Content lists -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Available lists -->
            <Border Grid.Column="0" BorderBrush="{StaticResource BrushBorder}" BorderThickness="1" CornerRadius="4">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="{DynamicResource S.PC.Available}" Foreground="{StaticResource BrushGold}" FontSize="11" Padding="8,4"/>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="AvailableLists" Margin="4">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{StaticResource BrushBorder}" BorderThickness="0,0,0,1" Padding="4,2">
                                        <DockPanel>
                                            <Button Content="+" DockPanel.Dock="Right" Width="24" Height="24" Margin="4,0,0,0"
                                                    Click="AddList_Click" Tag="{Binding Name}" ToolTip="{DynamicResource S.PC.AddTip}"/>
                                            <StackPanel>
                                                <TextBlock Text="{Binding Name}" Foreground="{StaticResource BrushText}" FontSize="11" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding Description}" Foreground="{StaticResource BrushTextDim}" FontSize="9" TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                        </DockPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- Buttons -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0">
                <Button Content="→" Width="32" Height="32" Margin="0,4" Click="AddAll_Click" ToolTip="{DynamicResource S.PC.AddAll}"/>
                <Button Content="←" Width="32" Height="32" Margin="0,4" Click="RemoveAll_Click" ToolTip="{DynamicResource S.PC.RemoveAll}"/>
            </StackPanel>

            <!-- Selected lists -->
            <Border Grid.Column="2" BorderBrush="{StaticResource BrushBorder}" BorderThickness="1" CornerRadius="4">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="{DynamicResource S.PC.Selected}" Foreground="{StaticResource BrushGold}" FontSize="11" Padding="8,4"/>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="SelectedLists" Margin="4">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{StaticResource BrushBorder}" BorderThickness="0,0,0,1" Padding="4,2">
                                        <DockPanel>
                                            <Button Content="✕" DockPanel.Dock="Right" Width="24" Height="24" Margin="4,0,0,0"
                                                    Click="RemoveList_Click" Tag="{Binding Name}" ToolTip="{DynamicResource S.PC.RemoveTip}"/>
                                            <StackPanel>
                                                <TextBlock Text="{Binding Name}" Foreground="{StaticResource BrushText}" FontSize="11" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding Description}" Foreground="{StaticResource BrushTextDim}" FontSize="9" TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                        </DockPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>

        <!-- Create button -->
        <Button Grid.Row="3" Content="{DynamicResource S.PC.Create}" HorizontalAlignment="Right" Margin="0,12,0,0"
                Padding="16,8" FontSize="12" Click="CreatePool_Click"/>
    </Grid>
</Window>
