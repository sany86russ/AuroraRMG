<Window x:Class="Olden_Era___Template_Editor.BonusPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource S.Bonus.001}" Width="420" Height="390"
        Icon="pack://application:,,,/favicon.ico"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize" MinWidth="350" MinHeight="300"
        WindowStyle="None"
        Background="#0E1117"
        Foreground="#E7EBF3"
        FontFamily="Segoe UI" FontSize="13">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32" ResizeBorderThickness="5"
                      GlassFrameThickness="0,0,0,1" UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Border BorderBrush="{StaticResource BrushBorder}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="32"/>
                <RowDefinition Height="1"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Grid Grid.Row="0" Background="#12151D">
                <TextBlock Text="{DynamicResource S.Bonus.001}"
                           FontSize="12" FontWeight="SemiBold"
                           Foreground="{StaticResource BrushText}"
                           VerticalAlignment="Center" Margin="10,0,0,0"
                           MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"/>
                <Button Content="✕" Style="{StaticResource TitleBarCloseButton}"
                        HorizontalAlignment="Right"
                        ToolTip="{DynamicResource S.M.009}" Click="BtnClose_Click"/>
            </Grid>

            <!-- Gold divider -->
            <Rectangle Grid.Row="1" Fill="{StaticResource BrushBorder}"/>

            <!-- Content -->
            <DockPanel Grid.Row="2" Margin="14" Background="{StaticResource BrushPanel}">

                <!-- Buttons (bottom) -->
                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                            HorizontalAlignment="Right" Margin="0,10,0,0">
                    <Button x:Name="BtnAdd" Content="{DynamicResource S.M.092}" Width="90" Height="28"
                            Margin="0,0,8,0" IsDefault="True" Click="BtnAdd_Click"/>
                    <Button Content="{DynamicResource S.Spell.004}" Width="80" Height="28"
                            IsCancel="True" Click="BtnCancel_Click"/>
                </StackPanel>

                <!-- Main form -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>

                        <!-- Bonus type -->
                        <TextBlock Text="{DynamicResource S.Bonus.002}" Foreground="{StaticResource BrushTextDim}" FontSize="11" Margin="0,0,0,3"/>
                        <ComboBox x:Name="CmbType" Height="28"
                                  SelectionChanged="CmbType_Changed">
                            <ComboBoxItem Tag="1" Content="{DynamicResource S.Bonus.003}"/>
                            <ComboBoxItem Tag="2" Content="{DynamicResource S.Bonus.004}"/>
                            <ComboBoxItem Tag="3" Content="{DynamicResource S.Bonus.005}"/>
                            <ComboBoxItem Tag="4" Content="{DynamicResource S.Bonus.006}"/>
                            <ComboBoxItem Tag="5" Content="{DynamicResource S.Bonus.007}"/>
                            <ComboBoxItem Tag="6" Content="{DynamicResource S.Bonus.008}"/>
                            <ComboBoxItem Tag="7" Content="{DynamicResource S.Bonus.009}"/>
                            <ComboBoxItem Tag="8" Content="{DynamicResource S.Bonus.010}"/>
                            <ComboBoxItem Tag="9" Content="{DynamicResource S.Bonus.011}"/>
                            <ComboBoxItem Tag="10" Content="{DynamicResource S.Bonus.012}"/>
                        </ComboBox>

                        <!-- Receiver -->
                        <StackPanel x:Name="PnlReceiver">
                            <TextBlock Text="{DynamicResource S.Bonus.013}" Foreground="{StaticResource BrushTextDim}" FontSize="11" Margin="0,8,0,3"/>
                            <ComboBox x:Name="CmbReceiver" Height="28">
                                <ComboBoxItem Tag="start_hero" Content="{DynamicResource S.Bonus.014}"/>
                                <ComboBoxItem Tag="all_heroes" Content="{DynamicResource S.Bonus.015}"/>
                            </ComboBox>
                        </StackPanel>

                        <!-- ── Dynamic parameter panels ── -->

                        <!-- Spell -->
                        <StackPanel x:Name="PnlSpell" Margin="0,8,0,0">
                            <TextBlock Text="{DynamicResource S.Bonus.003}" Foreground="{StaticResource BrushTextDim}" FontSize="11" Margin="0,0,0,3"/>
                            <DockPanel>
                                <Button DockPanel.Dock="Right" Content="{DynamicResource S.Bonus.016}" Width="64"
                                        Height="26" Margin="6,0,0,0" Click="BtnPickSpell_Click"/>
                                <TextBox x:Name="TxtSpell" Height="26" IsReadOnly="True"
                                         FontFamily="Consolas" FontSize="11"/>
                            </DockPanel>
                            <CheckBox x:Name="ChkMakeFree" Margin="0,8,0,0"
                                      Content="{DynamicResource S.Bonus.017}"/>
                        </StackPanel>

                        <!-- Unit Multiplier -->
                        <StackPanel x:Name="PnlMultiplier" Visibility="Collapsed" Margin="0,8,0,0">
                            <TextBlock Text="{DynamicResource S.Bonus.018}"
                                       Foreground="{StaticResource BrushTextDim}" FontSize="11" Margin="0,0,0,3"/>
                            <TextBox x:Name="TxtMultiplier" Height="26" Text="2"/>
                        </StackPanel>

                        <!-- Movement Bonus -->
                        <StackPanel x:Name="PnlMovement" Visibility="Collapsed" Margin="0,8,0,0">
                            <TextBlock Text="{DynamicResource S.Bonus.019}"
                                       Foreground="{StaticResource BrushTextDim}" FontSize="11" Margin="0,0,0,3"/>
                            <TextBox x:Name="TxtMovement" Height="26" Text="0"/>
                        </StackPanel>

                        <!-- Starting Item -->
                        <StackPanel x:Name="PnlItem" Visibility="Collapsed" Margin="0,8,0,0">
                            <TextBlock Text="{DynamicResource S.Bonus.020}" Foreground="{StaticResource BrushTextDim}" FontSize="11" Margin="0,0,0,3"/>
                            <DockPanel>
                                <Button DockPanel.Dock="Right" Content="{DynamicResource S.Bonus.016}" Width="64"
                                        Height="26" Margin="6,0,0,0" Click="BtnPickItem_Click"/>
                                <TextBox x:Name="TxtItem" Height="26"
                                         FontFamily="Consolas" FontSize="11"/>
                            </DockPanel>
                        </StackPanel>

                        <!-- Resources (Gold / Gems / Crystals / Mercury) -->
                        <StackPanel x:Name="PnlResources" Visibility="Collapsed" Margin="0,8,0,0">
                            <TextBlock x:Name="LblResourceAmount" Text="{DynamicResource S.Bonus.021}"
                                       Foreground="{StaticResource BrushTextDim}" FontSize="11" Margin="0,0,0,3"/>
                            <TextBox x:Name="TxtResourceAmount" Height="26" Text="10000"/>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Grid>
    </Border>
</Window>
