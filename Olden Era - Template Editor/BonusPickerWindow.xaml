<Window x:Class="Olden_Era___Template_Editor.BonusPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавить бонус" Width="420" Height="390"
        Icon="pack://application:,,,/favicon.ico"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize" MinWidth="350" MinHeight="300"
        WindowStyle="None"
        Background="#0E1117"
        Foreground="#E7EBF3"
        FontFamily="Segoe UI" FontSize="13">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32" ResizeBorderThickness="5"
                      GlassFrameThickness="0,0,0,1" UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Border BorderBrush="{StaticResource BrushBorder}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="32"/>
                <RowDefinition Height="1"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Grid Grid.Row="0" Background="#12151D">
                <TextBlock Text="Добавить бонус"
                           FontSize="12" FontWeight="SemiBold"
                           Foreground="{StaticResource BrushText}"
                           VerticalAlignment="Center" Margin="10,0,0,0"
                           MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"/>
                <Button Content="✕" Style="{StaticResource TitleBarCloseButton}"
                        HorizontalAlignment="Right"
                        ToolTip="Закрыть" Click="BtnClose_Click"/>
            </Grid>

            <!-- Gold divider -->
            <Rectangle Grid.Row="1" Fill="{StaticResource BrushBorder}"/>

            <!-- Content -->
            <DockPanel Grid.Row="2" Margin="14" Background="{StaticResource BrushPanel}">

                <!-- Buttons (bottom) -->
                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                            HorizontalAlignment="Right" Margin="0,10,0,0">
                    <Button x:Name="BtnAdd" Content="Добавить" Width="90" Height="28"
                            Margin="0,0,8,0" IsDefault="True" Click="BtnAdd_Click"/>
                    <Button Content="Отмена" Width="80" Height="28"
                            IsCancel="True" Click="BtnCancel_Click"/>
                </StackPanel>

                <!-- Main form -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>

                        <!-- Bonus type -->
                        <TextBlock Text="Тип бонуса" Foreground="{StaticResource BrushTextDim}" FontSize="11" Margin="0,0,0,3"/>
                        <ComboBox x:Name="CmbType" Height="28"
                                  SelectionChanged="CmbType_Changed">
                            <ComboBoxItem Tag="1" Content="Заклинание"/>
                            <ComboBoxItem Tag="2" Content="Множитель армии"/>
                            <ComboBoxItem Tag="3" Content="Бонус к ходу"/>
                            <ComboBoxItem Tag="4" Content="Стартовый предмет"/>
                            <ComboBoxItem Tag="5" Content="Стартовое золото"/>
                            <ComboBoxItem Tag="6" Content="Стартовые самоцветы"/>
                            <ComboBoxItem Tag="7" Content="Стартовые кристаллы"/>
                            <ComboBoxItem Tag="8" Content="Стартовая ртуть"/>
                            <ComboBoxItem Tag="9" Content="Стартовая древесина"/>
                            <ComboBoxItem Tag="10" Content="Стартовая руда"/>
                        </ComboBox>

                        <!-- Receiver -->
                        <StackPanel x:Name="PnlReceiver">
                            <TextBlock Text="Применяется к" Foreground="{StaticResource BrushTextDim}" FontSize="11" Margin="0,8,0,3"/>
                            <ComboBox x:Name="CmbReceiver" Height="28">
                                <ComboBoxItem Tag="start_hero" Content="Стартовый герой"/>
                                <ComboBoxItem Tag="all_heroes" Content="Все герои"/>
                            </ComboBox>
                        </StackPanel>

                        <!-- ── Dynamic parameter panels ── -->

                        <!-- Spell -->
                        <StackPanel x:Name="PnlSpell" Margin="0,8,0,0">
                            <TextBlock Text="Заклинание" Foreground="{StaticResource BrushTextDim}" FontSize="11" Margin="0,0,0,3"/>
                            <DockPanel>
                                <Button DockPanel.Dock="Right" Content="Выбрать…" Width="64"
                                        Height="26" Margin="6,0,0,0" Click="BtnPickSpell_Click"/>
                                <TextBox x:Name="TxtSpell" Height="26" IsReadOnly="True"
                                         FontFamily="Consolas" FontSize="11"/>
                            </DockPanel>
                            <CheckBox x:Name="ChkMakeFree" Margin="0,8,0,0"
                                      Content="Сделать заклинание бесплатным (0 маны)"/>
                        </StackPanel>

                        <!-- Unit Multiplier -->
                        <StackPanel x:Name="PnlMultiplier" Visibility="Collapsed" Margin="0,8,0,0">
                            <TextBlock Text="Множитель (напр. 2 = удвоенная стартовая армия)"
                                       Foreground="{StaticResource BrushTextDim}" FontSize="11" Margin="0,0,0,3"/>
                            <TextBox x:Name="TxtMultiplier" Height="26" Text="2"/>
                        </StackPanel>

                        <!-- Movement Bonus -->
                        <StackPanel x:Name="PnlMovement" Visibility="Collapsed" Margin="0,8,0,0">
                            <TextBlock Text="Доп. клетки передвижения (0 = по умолчанию)"
                                       Foreground="{StaticResource BrushTextDim}" FontSize="11" Margin="0,0,0,3"/>
                            <TextBox x:Name="TxtMovement" Height="26" Text="0"/>
                        </StackPanel>

                        <!-- Starting Item -->
                        <StackPanel x:Name="PnlItem" Visibility="Collapsed" Margin="0,8,0,0">
                            <TextBlock Text="ID артефакта" Foreground="{StaticResource BrushTextDim}" FontSize="11" Margin="0,0,0,3"/>
                            <DockPanel>
                                <Button DockPanel.Dock="Right" Content="Выбрать…" Width="64"
                                        Height="26" Margin="6,0,0,0" Click="BtnPickItem_Click"/>
                                <TextBox x:Name="TxtItem" Height="26"
                                         FontFamily="Consolas" FontSize="11"/>
                            </DockPanel>
                        </StackPanel>

                        <!-- Resources (Gold / Gems / Crystals / Mercury) -->
                        <StackPanel x:Name="PnlResources" Visibility="Collapsed" Margin="0,8,0,0">
                            <TextBlock x:Name="LblResourceAmount" Text="Количество"
                                       Foreground="{StaticResource BrushTextDim}" FontSize="11" Margin="0,0,0,3"/>
                            <TextBox x:Name="TxtResourceAmount" Height="26" Text="10000"/>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Grid>
    </Border>
</Window>
